@model TransactionHistoryViewModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="card mb-4">
    <div class="card-header">
        <h4 class="mb-0">Transaction History</h4>
    </div>
    <div class="card-body">
        <form method="get" asp-action="History" class="row g-3">
            <div class="col-md-5">
                <label class="form-label" for="accountNumber">Account Number</label>
                <input id="accountNumber" name="accountNumber" class="form-control" value="@Model.AccountNumber" placeholder="Leave empty for all" />
            </div>
            <div class="col-md-4">
                <label class="form-label" for="filter">Filter</label>
                <select id="filter" name="filter" class="form-select" asp-for="Filter" asp-items="Html.GetEnumSelectList<TransactionFilter>()"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label" for="pageSize">Page Size</label>
                <select id="pageSize" name="pageSize" class="form-select">
                    <option value="5" selected="@(Model.PageSize == 5)">5</option>
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Account</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Transactions.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">No transactions found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr>
                            <td>@transaction.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@transaction.AccountNumber</td>
                            <td>@transaction.Type</td>
                            <td>@transaction.Amount.ToString("C")</td>
                            <td>@transaction.Description</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <div class="text-muted">
            Showing @Model.Transactions.Count of @Model.TotalItems transactions
        </div>

        <nav aria-label="Transaction history pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-action="History"
                       asp-route-accountNumber="@Model.AccountNumber"
                       asp-route-filter="@Model.Filter"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : string.Empty)">
                        <a class="page-link"
                           asp-action="History"
                           asp-route-accountNumber="@Model.AccountNumber"
                           asp-route-filter="@Model.Filter"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-action="History"
                       asp-route-accountNumber="@Model.AccountNumber"
                       asp-route-filter="@Model.Filter"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
