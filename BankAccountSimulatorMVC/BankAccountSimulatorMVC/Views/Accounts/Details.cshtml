@model BankAccount

@{
    ViewData["Title"] = "Account Details";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Account @Model.AccountNumber</h4>
                @if (Model.Status == AccountStatus.Active)
                {
                    <span class="badge bg-label-success">Active</span>
                }
                else
                {
                    <span class="badge bg-label-warning">Frozen</span>
                }
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="text-muted">Owner</div>
                        <div class="fw-semibold">@Model.OwnerName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Balance</div>
                        <div class="fw-semibold">@Model.Balance.ToString("C")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Created At</div>
                        <div class="fw-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Transactions</h5>
            </div>
            <div class="card-body d-flex flex-wrap gap-2">
                <a asp-controller="Transactions" asp-action="Deposit" asp-route-accountNumber="@Model.AccountNumber" class="btn btn-success">Deposit</a>
                <a asp-controller="Transactions" asp-action="Withdraw" asp-route-accountNumber="@Model.AccountNumber" class="btn btn-warning">Withdraw</a>
                <a asp-controller="Transactions" asp-action="Transfer" asp-route-sourceAccountNumber="@Model.AccountNumber" class="btn btn-info">Transfer</a>
                <a asp-controller="Transactions" asp-action="History" asp-route-accountNumber="@Model.AccountNumber" class="btn btn-outline-primary">History</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Account Status</h5>
            </div>
            <div class="card-body">
                @if (Model.Status == AccountStatus.Active)
                {
                    <form asp-action="Freeze" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="accountNumber" value="@Model.AccountNumber" />
                        <button type="submit" class="btn btn-outline-warning w-100">Freeze Account</button>
                    </form>
                }
                else
                {
                    <form asp-action="Unfreeze" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="accountNumber" value="@Model.AccountNumber" />
                        <button type="submit" class="btn btn-outline-success w-100">Unfreeze Account</button>
                    </form>
                }
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Back to Accounts</a>
        </div>
    </div>
</div>
