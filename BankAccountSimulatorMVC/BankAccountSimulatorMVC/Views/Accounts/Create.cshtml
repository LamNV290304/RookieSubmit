@model CreateAccountViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">Create New Account</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AccountNumber" class="form-label"></label>
                        <input asp-for="AccountNumber" class="form-control" placeholder="e.g. 2001" />
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OwnerName" class="form-label"></label>
                        <input asp-for="OwnerName" class="form-control" placeholder="Owner full name" />
                        <span asp-validation-for="OwnerName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InitialBalance" class="form-label"></label>
                        <input asp-for="InitialBalance" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="InitialBalance" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
