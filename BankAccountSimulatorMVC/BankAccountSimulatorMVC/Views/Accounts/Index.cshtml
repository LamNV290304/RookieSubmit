@model AccountsIndexViewModel

@{
    ViewData["Title"] = "Accounts";
}

<div class="card">
    <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <h4 class="mb-0">Bank Accounts</h4>
        <div class="d-flex align-items-center gap-2">
            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
                <label for="pageSize" class="mb-0">Page Size</label>
                <select id="pageSize" name="pageSize" class="form-select form-select-sm" style="width: auto;">
                    <option value="5" selected="@(Model.PageSize == 5)">5</option>
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="btn btn-sm btn-outline-secondary">Apply</button>
            </form>
            <a asp-action="Create" class="btn btn-primary">Create New Account</a>
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Account Number</th>
                    <th>Owner</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Accounts.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">No accounts found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var account in Model.Accounts)
                    {
                        <tr>
                            <td>@account.AccountNumber</td>
                            <td>@account.OwnerName</td>
                            <td>@account.Balance.ToString("C")</td>
                            <td>
                                @if (account.Status == AccountStatus.Active)
                                {
                                    <span class="badge bg-label-success text-dark">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-warning text-danger">Frozen</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-accountNumber="@account.AccountNumber">Details</a>
                                    <a class="btn btn-sm btn-outline-info" asp-controller="Transactions" asp-action="History" asp-route-accountNumber="@account.AccountNumber">History</a>

                                    @if (account.Status == AccountStatus.Active)
                                    {
                                        <form asp-action="Freeze" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="accountNumber" value="@account.AccountNumber" />
                                            <input type="hidden" name="page" value="@Model.CurrentPage" />
                                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">Freeze</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Unfreeze" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="accountNumber" value="@account.AccountNumber" />
                                            <input type="hidden" name="page" value="@Model.CurrentPage" />
                                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">Unfreeze</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <div class="text-muted">
            Showing @Model.Accounts.Count of @Model.TotalItems accounts
        </div>

        <nav aria-label="Accounts pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : string.Empty)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
